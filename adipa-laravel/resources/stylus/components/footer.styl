.site-footer
  background #474b69
  color white

.site-footer__grid
  display grid
  gap 32px
  grid-template-columns 280px minmax(0,1fr) 300px
  padding-top 56px
  padding-bottom 40px

.site-footer__brand-card,
.site-footer__contact-grid,
.site-footer__newsletter
  border 1px solid rgba(255,255,255,.08)
  border-radius 18px
  background rgba(255,255,255,.03)

.site-footer__brand-card,
.site-footer__newsletter
  padding 24px

.site-footer__brand-card img
  width 162px
  filter brightness(0) invert(1)

.site-footer__brand-card p
  margin 24px 0 16px
  font-size 15px
  font-weight 700

.site-footer__countries,
.site-footer__groups,
.site-footer__contact-grid section
  display flex
  flex-direction column

.site-footer__countries a
  display flex
  align-items center
  gap 12px
  border-radius 10px
  padding 8px 8px
  font-size 15px
  font-weight 500
  color rgba(255,255,255,.92)

.site-footer__groups a
  display block
  border-radius 8px
  padding 6px 8px
  font-size 13px
  font-weight 500
  color rgba(255,255,255,.88)

.site-footer__contact-grid a
  display block
  border-radius 8px
  padding 6px 8px
  font-size 14px
  color rgba(255,255,255,.92)
  text-decoration underline
  text-underline-offset 2px

.site-footer__countries a:hover,
.site-footer__groups a:hover,
.site-footer__contact-grid a:hover
  background rgba(255,255,255,.06)
  color white
  text-decoration none

.site-footer__content
  display flex
  flex-direction column
  gap 24px

.site-footer__groups
  display grid
  grid-template-columns repeat(4,minmax(0,1fr))
  gap 24px

.site-footer__groups h3,
.site-footer__contact-grid h3
  margin 0 0 16px
  color #a8afe6
  font-size 12px
  font-weight 800
  text-transform uppercase
  letter-spacing .12em

.site-footer__contact-grid
  display grid
  grid-template-columns 1.2fr .8fr
  gap 20px
  padding 20px

.site-footer__contact-grid p
  margin 0 0 8px
  font-size 14px
  line-height 1.8
  color rgba(255,255,255,.9)

.site-footer__newsletter h3
  margin 0 0 16px
  font-size 15px
  font-weight 800
  line-height 1.8
  text-transform uppercase

.site-footer__newsletter label
  display block
  margin-bottom 12px

.site-footer__newsletter span
  display block
  margin-bottom 6px
  font-size 13px
  font-weight 700
  color white

.site-footer__newsletter input,
.site-footer__newsletter select
  width 100%
  height 40px
  border 1px solid rgba(255,255,255,.1)
  border-radius 8px
  padding 0 12px
  background white
  color #27223f
  outline none

.site-footer__newsletter select
  color #a7a9b4

.site-footer__newsletter button
  display inline-flex
  align-items center
  justify-content center
  height 40px
  border 0
  border-radius 8px
  background #78cafd
  padding 0 24px
  color white
  font-size 14px
  font-weight 700
  margin-top 8px

.site-footer__newsletter p
  margin 20px 0 0
  font-size 14px
  line-height 1.8
  color rgba(255,255,255,.88)

.site-footer__bottom
  display flex
  justify-content flex-end
  gap 16px
  border-top 1px solid rgba(255,255,255,.1)
  padding-top 24px
  margin-top 32px
  padding-bottom 40px

.site-footer__bottom a
  width 36px
  height 36px
  border-radius 50%
  background white
  color #474b69
  display inline-flex
  align-items center
  justify-content center
  font-size 12px
  font-weight 700
