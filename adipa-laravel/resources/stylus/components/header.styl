.site-header
  position fixed
  inset 0 0 auto 0
  z-index 40
  background white
  border-bottom 1px solid #e8e2f8
  box-shadow 0 1px 2px rgba(17,11,43,.04)

.site-header__desktop
  display block

.site-header__main-row
  display flex
  min-height 72px
  align-items center
  gap 24px
  padding 12px 0

.site-header__brand
  line-height 0
  flex-shrink 0

.site-header__brand img
  width 182px
  height auto

.site-header__brand--mobile img
  width 150px

.site-header__search-wrap
  display flex
  flex 1
  align-items center

.site-header__search-form
  width 100%

.site-header__search
  display flex
  width 100%
  height 38px
  overflow hidden
  border 1px solid #35a8f5
  border-radius 4px
  background white

.site-header__search input
  width 100%
  border 0
  outline 0
  padding 0 16px
  color #53506a
  font-size 14px
  font-weight 400
  line-height 1.2
  letter-spacing 0
  background transparent
  -webkit-font-smoothing antialiased

.site-header__search input::placeholder
  color #a19db5
  opacity 1
  font-weight 400
  letter-spacing 0

.site-header__search button
  display flex
  width 48px
  min-width 48px
  align-items center
  justify-content center
  padding 0
  border 0
  background #35a8f5
  cursor pointer

.site-header__search button img
  width 18px

.site-header__account
  display flex
  flex-shrink 0
  align-items center
  gap 20px
  font-size 14px

.site-header__account-link
  color #27223f
  font-weight 700

.site-header__register-link
  color #4e4a68
  font-weight 500

.site-header__account-link:hover,
.site-header__register-link:hover,
.site-header__dropdown-trigger:hover,
.site-header__nav-item:hover
  color #6d44f7

.site-header__icon-button
  display flex
  width 32px
  height 32px
  align-items center
  justify-content center
  padding 0
  border 0
  background transparent
  cursor pointer

.site-header__icon-button img
  width 18px

.site-header__cart-button
  position relative
  display flex
  align-items center
  justify-content center
  padding 0
  border 0
  background transparent
  cursor pointer

.site-header__cart-button img
  width 20px

.site-header__cart-count
  margin-left 4px
  color #27223f
  font-size 13px
  font-weight 600

.site-header__cart-badge
  position absolute
  right -8px
  top -4px
  min-width 16px
  padding 0 4px
  border-radius 999px
  background #6d44f7
  color white
  font-size 10px
  font-weight 700
  line-height 16px
  text-align center

.site-header__nav-row
  display flex
  min-height 44px
  align-items center
  gap 16px
  border-top 1px solid #f0edf9
  padding 4px 0

.site-header__nav-left
  display flex
  flex-shrink 0
  align-items center
  gap 12px

.site-header__whatsapp
  display flex
  align-items center
  justify-content center

.site-header__whatsapp img
  width 26px
  height auto

.site-header__dropdown
  position relative

.site-header__dropdown-trigger
  display flex
  align-items center
  gap 4px
  padding 0
  border 0
  background transparent
  color #53506a
  font-size 14px
  font-weight 500
  line-height 1
  cursor pointer

.site-header__dropdown-menu
  visibility hidden
  position absolute
  left 0
  top 100%
  z-index 50
  min-width 200px
  margin-top 4px
  overflow hidden
  border 1px solid #ece9f5
  border-radius 6px
  background white
  box-shadow 0 8px 24px rgba(17,11,43,.14)

.site-header__dropdown-menu--right
  left auto
  right 0
  min-width 190px

.site-header__dropdown:hover > .site-header__dropdown-menu,
.site-header__submenu:hover > .site-header__submenu-menu
  visibility visible

.site-header__dropdown-link,
.site-header__submenu-trigger
  display flex
  width 100%
  align-items center
  justify-content space-between
  padding 10px 16px
  border 0
  background white
  color #27223f
  font-size 13px
  text-align left

.site-header__dropdown-link:hover,
.site-header__submenu-trigger:hover
  background #faf8ff

.site-header__submenu
  position relative

.site-header__submenu-menu
  visibility hidden
  position absolute
  left 100%
  top 0
  z-index 51
  min-width 200px
  margin-left 4px
  overflow hidden
  border 1px solid #ece9f5
  border-radius 6px
  background white
  box-shadow 0 8px 24px rgba(17,11,43,.14)

.site-header__submenu-chevron
  color #9a96b0
  font-size 11px

.site-header__nav
  display flex
  flex-wrap wrap
  align-items center
  gap 20px
  margin-left auto
  color #5b566f
  font-size 14px
  font-weight 500

.site-header__nav-item
  position relative
  display flex
  align-items center
  gap 4px
  color inherit

.site-header__nav-item.is-active
  color #27223f
  font-weight 800

.site-header__nav-item.is-bold
  font-weight 700

.site-header__nav-item.is-pink
  padding .125rem .5rem
  border-radius 4px
  background #fff0f5

.site-header__chevron
  color inherit
  font-size 10px

.site-header__badge
  position absolute
  top -14px
  left 50%
  transform translateX(-50%)
  border-radius 3px
  padding 1px 6px
  background #ff2f7d
  color white
  font-size 8px
  font-weight 800
  letter-spacing .06em
  text-transform uppercase

.site-header__badge.is-free
  background #6d44f7

.site-header__mobile
  display none

.site-header__mobile-actions
  display flex
  align-items center
  gap 8px

.site-header__icon-button--mobile
  width 36px
  height 36px

.site-header__cart-button--mobile
  width 36px
  height 36px

.site-header__cart-badge--mobile
  right -4px
  top -4px

.site-header__hamburger
  display flex
  width 36px
  height 36px
  align-items center
  justify-content center
  border 0
  background transparent
  cursor pointer

.site-header__hamburger span
  display block
  width 26px
  height 3px
  margin-bottom 5px
  border-radius 999px
  background #27223f

.site-header__hamburger span:last-child
  margin-bottom 0
