.catalog-hero
  position relative
  isolation isolate
  overflow hidden
  background linear-gradient(90deg,#6843f7 0%,#744cff 48%,#6f47fb 100%)
  color white

.catalog-hero:before
  content ''
  position absolute
  inset 0
  background linear-gradient(180deg, rgba(255,255,255,.05) 0%, rgba(255,255,255,.02) 100%)
  pointer-events none

.catalog-hero__content
  position relative
  width 100%
  max-width 1400px
  margin 0 auto
  padding-left 20px
  padding-right 20px
  padding-top 40px
  padding-bottom 40px

.catalog-hero__inner
  max-width 1120px
  margin 0 auto

.catalog-hero__copy
  max-width 1120px
  margin 0 auto
  text-align center

.catalog-hero h1
  max-width none
  margin 0 auto
  font-size 36px
  font-weight 600
  line-height 48px
  letter-spacing 0
  text-align center
  -webkit-font-smoothing antialiased
  -moz-osx-font-smoothing grayscale

.catalog-hero p
  max-width 760px
  margin 20px auto 0
  font-size 14px
  font-weight 400
  line-height 26px
  color rgba(255,255,255,.88)
  text-align center
  -webkit-font-smoothing antialiased
  -moz-osx-font-smoothing grayscale

.catalog-hero__search-shell
  width 100%
  max-width 620px
  margin 40px auto 0

.catalog-hero__search
  width 100%
  display flex
  align-items center
  padding-bottom 8px
  border-bottom 1px solid rgba(255,255,255,.75)

.catalog-hero__cursor
  width 2px
  height 25px
  margin-right 8px
  background rgba(255,255,255,.96)
  animation heroCursor 1s steps(2) infinite
  flex-shrink 0

.catalog-hero__search input
  width 100%
  height 44px
  flex 1
  background transparent
  border 0
  outline 0
  color white
  -webkit-text-fill-color white
  caret-color transparent
  padding 0 8px
  padding-right 48px
  font-size 24px
  font-weight 700
  line-height 1
  letter-spacing 0

.catalog-hero__search input::placeholder
  color transparent
  -webkit-text-fill-color transparent

.catalog-hero__search button
  border 0
  background transparent
  color white
  display flex
  flex-shrink 0
  align-items center
  justify-content center
  padding 0
  margin-left 0
  padding-left 15px
  padding-right 15px

.catalog-hero__search button svg
  width 16px
  height 16px

.catalog-hero__tags
  margin-top 36px
  display flex
  flex-wrap wrap
  align-items center
  justify-content center
  gap 8px 10px
  font-size 14px
  color rgba(255,255,255,.95)

.catalog-hero__tags > p
  margin 0
  font-weight 400
  color white

.catalog-hero__tags-list
  display flex
  flex-wrap wrap
  align-items center
  justify-content center

.catalog-hero__tags button
  display inline-block
  margin 0 5px 5px
  border 1px solid rgba(255,255,255,1)
  background rgba(255,255,255,.3)
  color white
  border-radius 7px
  padding 0 10px
  line-height 26px
  font-size 13px
  font-weight 500

@media (min-width: 640px)
  .catalog-hero h1
    font-size 38px
    line-height 48px

@media (min-width: 1024px)
  .catalog-hero__content
    padding-left 40px
    padding-right 40px
    padding-top 64px
    padding-bottom 64px


@keyframes heroCursor
  0%, 48%
    opacity 1
  49%, 100%
    opacity 0

.catalog-layout
  display flex
  gap 24px
  padding-top 32px
  padding-bottom 32px

.filters-panel
  width 292px
  flex-shrink 0
  margin-top 58px
  border 1px solid #f0eef9
  border-radius 28px
  background white
  padding 28px
  box-shadow 0 18px 40px rgba(31,22,87,.055)

.filters-panel__ranking
  display flex
  flex-direction column
  gap 12px
  padding-bottom 28px
  border-bottom 1px solid #eceef6

.filters-panel__ranking button,
.filters-panel__clear
  border 0
  background transparent
  text-align left
  font-size 15px
  font-weight 800
  color #232041
  cursor pointer
  line-height 1.4

.filters-panel__ranking button
  display block
  width 100%
  padding 0

.filters-panel__ranking button.is-active
  color $brand

.filters-panel__head
  display flex
  justify-content space-between
  padding-top 24px
  padding-bottom 16px
  color #a1a1b6
  font-size 15px
  font-weight 500

.filters-panel__head h3
  margin 0
  font-size 15px
  font-weight 500
  line-height 1.2

.filter-section
  border-bottom 1px solid #f1eff7
  padding 4px 0 5px

.filter-section__toggle
  width 100%
  border 0
  background transparent
  display flex
  justify-content space-between
  align-items center
  color #261f53
  font-weight 800
  font-size 16px
  margin 0
  padding 16px 0 17px
  line-height 1.3

.filter-section__chevron
  display none

.filter-section__chevron-wrap
  display flex
  width 32px
  min-width 32px
  height 32px
  align-items center
  justify-content center
  border 1px solid transparent
  border-radius 999px
  background transparent
  color #b2b6c8
  transition transform .18s ease, color .18s ease, border-color .18s ease, background-color .18s ease

.filter-section__chevron-wrap svg
  width 16px
  height 16px

.filter-section.is-open .filter-section__toggle
  color #6d44f7

.filter-section.is-open .filter-section__chevron-wrap
  transform rotate(180deg)
  color #6d44f7
  border-color #dcd6ff
  background #f3f0ff

.filter-section__body
  display none
  padding 0 0 20px

.filter-section.is-open .filter-section__body
  display block

.filter-section__body label
  display flex
  gap 12px
  color #7180a0
  margin-bottom 10px
  line-height 1.6
  font-size 13px

.range-values
  display flex
  justify-content space-between
  margin-bottom 12px
  color #687590
  font-weight 700
  font-size 15px

.filters-panel__clear
  width 100%
  margin-top 24px
  height 52px
  border-radius 12px
  background #f1efff
  color #7a5cff
  padding 0 12px
  text-align center
  font-size 16px
  font-weight 600

.catalog-results
  flex 1
  min-width 0

.catalog-results__toolbar
  display flex
  justify-content space-between
  align-items center
  gap 16px
  margin-bottom 24px

.catalog-results__toolbar p
  font-size 12px
  color $brand
  font-weight 700

.catalog-results__sorting
  display flex
  align-items center
  gap 8px
  flex-wrap wrap

.catalog-results__sorting span
  font-size 12px
  color $muted
  font-weight 700

.catalog-results__sorting button
  height 36px
  border 0
  border-radius 4px
  padding 0 12px
  background white
  color $muted
  font-size 12px
  font-weight 700
  cursor pointer

.catalog-results__sorting button.is-active
  background $brand
  color white

.catalog-results__grid
  display grid
  grid-template-columns repeat(3,minmax(0,1fr))
  gap 20px 16px

.course-card
  overflow hidden
  border 1px solid #e3e0f2
  border-radius 8px
  background white
  box-shadow 0 10px 22px rgba(31,22,87,.07)

.course-card__media
  position relative
  aspect-ratio 1.68 / 1
  background linear-gradient(135deg,#ddd2ff 0%,#d4c6ff 55%,#c9bbff 100%)

.course-card__media:before,
.checkout-item__thumb:before,
.cart-item__thumb:before
  content ''
  position absolute
  inset 0
  background radial-gradient(circle at top right, rgba(255,255,255,.5), transparent 30%), radial-gradient(circle at bottom left, rgba(255,255,255,.28), transparent 35%)

.course-card__media-logo,
.checkout-item__thumb,
.cart-item__thumb
  position relative
  display flex
  align-items center
  justify-content center

.course-card__media-logo
  width 100%
  height 100%
  padding 24px

.course-card__media-logo img,
.checkout-item__thumb img
  width 118px

.course-card__badge
  position absolute
  right 0
  bottom 12px
  display flex
  align-items center
  gap 8px
  height 36px
  padding 0 12px
  background white
  border 1px solid #dcd8ef
  border-right 0
  border-radius 6px 0 0 6px
  box-shadow 0 4px 12px rgba(31,22,87,.12)
  font-size 11px

.course-card__badge-dot
  width 8px
  height 8px
  border-radius 50%
  background #25b233

.course-card__badge-alert
  width 16px
  height 16px
  border 1px solid #7552ff
  border-radius 50%
  display inline-flex
  align-items center
  justify-content center
  color #7552ff
  font-size 10px
  font-weight 700

.course-card__body
  padding 20px

.course-card__body h3
  margin 0 0 16px
  min-height 76px
  font-size 16px
  font-weight 800
  line-height 1.15
  letter-spacing -.02em
  overflow hidden
  display -webkit-box
  -webkit-line-clamp 3
  -webkit-box-orient vertical

.course-card__meta
  display flex
  align-items center
  gap 10px
  color #696482
  font-size 12px

.course-card__meta-item
  display inline-flex
  align-items center
  gap 6px

.course-card__meta-item svg
  width 14px
  height 14px
  color #7552ff
  flex-shrink 0

.course-card__meta-divider
  width 4px
  height 4px
  border-radius 50%
  background #282143
  flex-shrink 0

.course-card__price-row
  display flex
  flex-wrap wrap
  gap 8px
  align-items center
  margin-top 20px

.course-card__old-price
  width 100%
  color #9590ab
  font-size 12px
  text-decoration line-through

.course-card__price-row strong
  font-size 19px
  font-weight 900
  letter-spacing -.03em

.course-card__discount
  background #31ace1
  color white
  font-size 8px
  font-weight 700
  padding 2px 6px
  border-radius 3px

.course-card__actions
  margin-top 20px
  display flex
  gap 12px
  align-items center

.course-card__detail
  flex 1
  height 44px
  border 1px solid #7352ff
  background white
  border-radius 6px
  color $ink
  font-weight 700

.course-card__cart-actions
  display flex
  gap 8px

.course-card__icon-button
  width 44px
  height 44px
  border 0
  border-radius 6px
  background $brand
  color white
  display inline-flex
  align-items center
  justify-content center
  box-shadow 0 8px 18px rgba(111,73,255,.28)

.course-card__icon-button img
  width 28px
  filter brightness(0) invert(1)

.course-card__icon-button svg
  width 18px
  height 18px

.catalog-results__empty
  border 1px solid #e8e3fb
  border-radius 28px
  background linear-gradient(180deg,#fcfbff 0%,#f7f4ff 100%)
  padding 32px

.catalog-results__empty h3
  margin 0 0 12px
  font-size 24px

.catalog-results__empty button
  margin-top 20px
  height 44px
  border 0
  border-radius 8px
  background $brand
  color white
  padding 0 20px

.catalog-cta
  padding-bottom 48px

.catalog-cta__box
  position relative
  overflow hidden
  border-radius 24px
  background linear-gradient(180deg,#f3f4ff 0%,#ecefff 100%)
  text-align center
  padding 56px 24px
  box-shadow 0 20px 40px rgba(86,70,180,.08)

.catalog-cta__box:before
  content ''
  position absolute
  inset 0
  background radial-gradient(circle at 50% 0%, rgba(255,255,255,.78) 0%, rgba(255,255,255,.18) 34%, rgba(255,255,255,0) 68%)
  pointer-events none

.catalog-cta__bg
  position absolute
  inset 0
  pointer-events none

.catalog-cta__bg-a
  position absolute
  left 50%
  bottom 0
  width 430px
  height 240px
  transform translateX(-50%)
  display none
  pointer-events none

.catalog-cta__bg-a-left
.catalog-cta__bg-a-right
  position absolute
  bottom 0
  height 92%
  width 26%
  background rgba(255,255,255,.18)

.catalog-cta__bg-a-left
  left 14%
  clip-path polygon(72% 0,100% 0,34% 100%,0 100%)

.catalog-cta__bg-a-right
  right 14%
  clip-path polygon(0 0,28% 0,100% 100%,66% 100%)

.catalog-cta__bg-a-crossbar
  position absolute
  bottom 14%
  left 50%
  width 160px
  height 72px
  transform translateX(-50%)
  background rgba(255,255,255,.28)
  clip-path polygon(16% 0,84% 0,100% 100%,0 100%)

.catalog-cta__bg-a-stem
  position absolute
  bottom 0
  left 32%
  width 22%
  height 100%
  transform skewX(-16deg)
  background rgba(255,255,255,.28)

.catalog-cta__box-content
  position relative
  z-index 1
  max-width 48rem
  margin 0 auto

.catalog-cta__box-content > span
  color $brand
  font-size 14px
  font-weight 800
  letter-spacing .16em
  text-transform uppercase

.catalog-cta__box h2
  margin 16px auto 0
  font-size 32px
  font-weight 800
  line-height 1.1
  letter-spacing -.03em
  color #27223f

.catalog-cta__box p
  max-width 42rem
  margin 24px auto 0
  color #73708e
  font-size 18px
  line-height 32px

.catalog-cta__box button
  display inline-flex
  align-items center
  justify-content center
  margin-top 32px
  height 52px
  border 0
  border-radius 8px
  background linear-gradient(90deg,#6d44f7 0%,#7a52ff 100%)
  color white
  padding 0 32px
  font-weight 600
  font-size 17px
  box-shadow 0 14px 26px rgba(109,68,247,.24)

@media (min-width: 640px)
  .catalog-cta__box
    padding 56px 40px

  .catalog-cta__bg-a
    display block

  .catalog-cta__box h2
    font-size 42px

@media (min-width: 1024px)
  .catalog-cta
    padding-bottom 64px

  .catalog-cta__box
    padding 72px 64px

.catalog-suggestion
  padding-bottom 56px

.catalog-suggestion__box
  position relative
  display flex
  flex-direction column
  gap 28px
  border-radius 24px
  background #6f4cff
  color white
  padding 28px 20px
  box-shadow 0 22px 44px rgba(109,68,247,.2)

.catalog-suggestion__box:before
  content none

.catalog-suggestion__box:after
  content none

.catalog-suggestion__content
  position relative
  z-index 1
  display flex
  flex-direction column
  gap 20px
  min-width 0

.catalog-suggestion__left
  display flex
  align-items flex-start
  gap 12px

.catalog-suggestion__icon
  width 44px
  height 44px
  flex-shrink 0
  display flex
  align-items center
  justify-content center
  border-radius 14px
  background rgba(255,255,255,.14)

.catalog-suggestion__icon svg
  width 24px
  height 24px

.catalog-suggestion__label
  display block
  font-size 12px
  font-weight 800
  text-transform uppercase
  letter-spacing .16em
  color rgba(255,255,255,.72)

.catalog-suggestion__box h3
  margin 8px 0 0
  max-width 280px
  font-size 24px
  font-weight 800
  line-height 1
  letter-spacing -.035em

.catalog-suggestion__content > p
  margin 0
  max-width 760px
  font-size 14px
  line-height 24px
  color rgba(255,255,255,.92)

.catalog-suggestion__cta
  display flex
  flex-direction column
  align-items flex-start
  gap 12px
  flex-shrink 0

.catalog-suggestion__cta button
  display inline-flex
  align-items center
  justify-content center
  height 48px
  width 100%
  border 0
  border-radius 10px
  background white
  color #6f4cff
  padding 0 24px
  font-size 15px
  font-weight 600
  cursor pointer
  box-shadow 0 14px 28px rgba(255,255,255,.14)

.catalog-suggestion__cta > p
  margin 0
  font-size 12px
  font-weight 500
  color rgba(255,255,255,.70)

@media (min-width: 768px)
  .catalog-suggestion__box
    padding 28px 32px

  .catalog-suggestion__icon
    width 48px
    height 48px

  .catalog-suggestion__box h3
    font-size 31px

  .catalog-suggestion__content > p
    font-size 16px
    line-height 32px

  .catalog-suggestion__cta button
    height 52px
    width auto
    padding 0 32px
    font-size 16px

@media (min-width: 1024px)
  .catalog-suggestion
    padding-bottom 80px

  .catalog-suggestion__box
    flex-direction row
    align-items center
    justify-content space-between
    padding 36px 40px

  .catalog-suggestion__content
    flex-direction row
    align-items flex-start
    gap 32px
    flex 1

  .catalog-suggestion__left
    flex-shrink 0

  .catalog-suggestion__box h3
    font-size 31px
    max-width 280px

  .catalog-suggestion__content > p
    max-width 760px
    font-size 16px
    line-height 32px

  .catalog-suggestion__cta
    align-items flex-end
    gap 12px
    flex-shrink 0

  .catalog-suggestion__cta > p
    max-width 18rem
    text-align right


.catalog-faq
  padding-bottom 72px

.catalog-faq__head span
  font-size 14px
  font-weight 800
  color $brand
  text-transform uppercase

.catalog-faq__head h2
  margin 12px 0 32px
  font-size 30px
  font-weight 800
  letter-spacing -.03em

.faq-item
  overflow hidden
  border 1px solid #f1eefc
  border-radius 16px
  background white
  box-shadow 0 10px 24px rgba(31,22,87,.05)
  margin-bottom 12px

.faq-item.is-open
  border-color #d9cffd
  background #fbfaff

.faq-item__toggle
  width 100%
  padding 18px 20px
  border 0
  background transparent
  display flex
  justify-content space-between
  align-items center
  text-align left
  gap 16px

.faq-item__toggle span:first-child
  font-size 17px
  font-weight 800
  line-height 1.2
  letter-spacing -.02em
  color $brand

.faq-item__icon
  width 32px
  min-width 32px
  height 32px
  border-radius 50%
  border 1px solid #ddd3ff
  background white
  display flex
  align-items center
  justify-content center
  color #8f74ff
  transition transform .2s ease, color .2s ease, border-color .2s ease, background-color .2s ease

.faq-item__icon svg
  width 14px
  height 14px

.faq-item__icon.is-open
  transform rotate(45deg)
  border-color #cfc2ff
  background #f6f1ff
  color $brand

.faq-item__body
  border-top 1px solid #ece6ff
  padding 18px 20px
  color #6f6a89
  font-size 14px
  line-height 28px

@media (min-width: 768px)
  .catalog-faq__head h2
    font-size 38px

  .faq-item__toggle
    padding 24px 32px
    gap 24px

  .faq-item__toggle span:first-child
    font-size 22px

  .faq-item__body
    padding 20px 32px 24px
    font-size 16px
    line-height 32px
