.catalog-hero
  position relative
  isolation isolate
  overflow hidden
  background linear-gradient(90deg,#6843f7 0%,#744cff 48%,#6f47fb 100%)
  color white

.catalog-hero__bg
  position absolute
  inset 0

.catalog-hero__bg:before
  content ''
  position absolute
  inset 0
  background linear-gradient(180deg, rgba(255,255,255,.08) 0%, rgba(255,255,255,.02) 100%)
  pointer-events none

.catalog-hero__polygon
  position absolute
  left 4.8%
  top 50.5%
  width 380px
  height 220px
  background rgba(255,255,255,.08)
  clip-path polygon(17% 0,81% 0,95% 66%,48% 66%,41% 100%,0 100%,0 78%)

.catalog-hero__bar1
  position absolute
  left 26.2%
  top -12%
  width 124px
  height 162%
  transform skewX(-19deg)
  background rgba(255,255,255,.10)

.catalog-hero__bar2
  position absolute
  left 34.8%
  top -14%
  width 86px
  height 168%
  transform skewX(-19deg)
  background rgba(255,255,255,.07)

.catalog-hero__content
  position relative
  display flex
  flex-direction column
  align-items center
  text-align center
  padding-top 64px
  padding-bottom 64px

.catalog-hero h1
  max-width 56rem
  margin 0
  font-size 34px
  font-weight 500
  line-height 1.25
  letter-spacing -.03em

.catalog-hero p
  max-width 56rem
  margin 24px auto 0
  font-size 16px
  font-weight 400
  color rgba(255,255,255,.9)

.catalog-hero__search
  width 100%
  max-width 640px
  display flex
  align-items center
  margin 40px auto 0
  padding-bottom 8px
  border-bottom 1px solid rgba(255,255,255,.75)

.catalog-hero__cursor
  width 2px
  height 26px
  margin-right 12px
  background rgba(255,255,255,.96)
  animation heroCursor 1s steps(2) infinite
  flex-shrink 0

.catalog-hero__search input
  width 100%
  height 40px
  flex 1
  background transparent
  border 0
  outline 0
  color white
  -webkit-text-fill-color white
  caret-color transparent
  font-size 18px
  font-weight 900
  letter-spacing -.035em

.catalog-hero__search input::placeholder
  color transparent
  -webkit-text-fill-color transparent

.catalog-hero__search button
  border 0
  background transparent
  color white
  display flex
  align-items center
  justify-content center
  padding 0
  margin-left 12px

.catalog-hero__search button svg
  width 30px
  height 30px

.catalog-hero__tags
  margin-top 40px
  display flex
  flex-wrap wrap
  align-items center
  justify-content center
  gap 12px
  font-size 14px
  color rgba(255,255,255,.95)

.catalog-hero__tags > span
  font-weight 500

.catalog-hero__tags button
  border 1px solid rgba(255,255,255,.8)
  background rgba(255,255,255,.08)
  color white
  border-radius 8px
  padding 6px 16px
  font-size 13px
  font-weight 500

@media (min-width: 640px)
  .catalog-hero h1
    font-size 44px

  .catalog-hero p
    font-size 17px

@media (min-width: 1024px)
  .catalog-hero__content
    padding-top 80px
    padding-bottom 80px


@keyframes heroCursor
  0%, 48%
    opacity 1
  49%, 100%
    opacity 0

.catalog-layout
  display flex
  gap 24px
  padding-top 32px
  padding-bottom 32px

.filters-panel
  width 292px
  flex-shrink 0
  margin-top 58px
  border 1px solid #f0eef9
  border-radius 28px
  background white
  padding 28px
  box-shadow 0 18px 40px rgba(31,22,87,.055)

.filters-panel__ranking
  display flex
  flex-direction column
  gap 12px
  padding-bottom 28px
  border-bottom 1px solid #eceef6

.filters-panel__ranking button,
.filters-panel__clear
  border 0
  background transparent
  text-align left
  font-size 15px
  font-weight 800
  color #232041
  cursor pointer

.filters-panel__ranking button.is-active
  color $brand

.filters-panel__head
  display flex
  justify-content space-between
  margin 24px 0 12px
  color #a1a1b6
  font-size 15px

.filter-section
  border-bottom 1px solid #eceef6

.filter-section__toggle
  width 100%
  min-height 60px
  border 0
  background transparent
  display flex
  justify-content space-between
  align-items center
  color #211c3d
  font-weight 800
  font-size 16px
  padding 16px 0

.filter-section__chevron
  color #aba7bf
  transition transform .18s ease

.filter-section.is-open .filter-section__chevron
  transform rotate(180deg)

.filter-section__body
  display none
  padding 0 0 20px

.filter-section.is-open .filter-section__body
  display block

.filter-section__body label
  display flex
  gap 12px
  color #7180a0
  margin-bottom 10px
  line-height 1.6
  font-size 13px

.range-values
  display flex
  justify-content space-between
  margin-bottom 12px
  color #687590
  font-weight 700
  font-size 15px

.filters-panel__clear
  width 100%
  margin-top 24px
  border-radius 24px
  background #f1efff
  color #7a5cff
  padding 16px 12px
  text-align center
  font-size 16px
  font-weight 600

.catalog-results
  flex 1
  min-width 0

.catalog-results__toolbar
  display flex
  justify-content space-between
  align-items center
  gap 16px
  margin-bottom 24px

.catalog-results__toolbar p
  font-size 12px
  color $brand
  font-weight 700

.catalog-results__sorting
  display flex
  align-items center
  gap 8px
  flex-wrap wrap

.catalog-results__sorting span
  font-size 12px
  color $muted
  font-weight 700

.catalog-results__sorting button
  height 36px
  border 0
  border-radius 4px
  padding 0 12px
  background white
  color $muted
  font-size 12px
  font-weight 700
  cursor pointer

.catalog-results__sorting button.is-active
  background $brand
  color white

.catalog-results__grid
  display grid
  grid-template-columns repeat(3,minmax(0,1fr))
  gap 20px 16px

.course-card
  overflow hidden
  border 1px solid #e3e0f2
  border-radius 8px
  background white
  box-shadow 0 10px 22px rgba(31,22,87,.07)

.course-card__media
  position relative
  aspect-ratio 1.68 / 1
  background linear-gradient(135deg,#ddd2ff 0%,#d4c6ff 55%,#c9bbff 100%)

.course-card__media:before,
.checkout-item__thumb:before,
.cart-item__thumb:before
  content ''
  position absolute
  inset 0
  background radial-gradient(circle at top right, rgba(255,255,255,.5), transparent 30%), radial-gradient(circle at bottom left, rgba(255,255,255,.28), transparent 35%)

.course-card__media-logo,
.checkout-item__thumb,
.cart-item__thumb
  position relative
  display flex
  align-items center
  justify-content center

.course-card__media-logo
  width 100%
  height 100%
  padding 24px

.course-card__media-logo img,
.checkout-item__thumb img
  width 118px

.course-card__badge
  position absolute
  right 0
  bottom 12px
  display flex
  align-items center
  gap 8px
  height 36px
  padding 0 12px
  background white
  border 1px solid #dcd8ef
  border-right 0
  border-radius 6px 0 0 6px
  box-shadow 0 4px 12px rgba(31,22,87,.12)
  font-size 11px

.course-card__badge-dot
  width 8px
  height 8px
  border-radius 50%
  background #25b233

.course-card__badge-alert
  width 16px
  height 16px
  border 1px solid #7552ff
  border-radius 50%
  display inline-flex
  align-items center
  justify-content center
  color #7552ff
  font-size 10px
  font-weight 700

.course-card__body
  padding 20px

.course-card__body h3
  margin 0 0 16px
  min-height 76px
  font-size 16px
  font-weight 800
  line-height 1.15
  letter-spacing -.02em
  overflow hidden
  display -webkit-box
  -webkit-line-clamp 3
  -webkit-box-orient vertical

.course-card__meta
  display flex
  align-items center
  gap 10px
  color #696482
  font-size 12px

.course-card__meta-item
  display inline-flex
  align-items center
  gap 6px

.course-card__meta-item svg
  width 14px
  height 14px
  color #7552ff
  flex-shrink 0

.course-card__meta-divider
  width 4px
  height 4px
  border-radius 50%
  background #282143
  flex-shrink 0

.course-card__price-row
  display flex
  flex-wrap wrap
  gap 8px
  align-items center
  margin-top 20px

.course-card__old-price
  width 100%
  color #9590ab
  font-size 12px
  text-decoration line-through

.course-card__price-row strong
  font-size 19px
  font-weight 900
  letter-spacing -.03em

.course-card__discount
  background #31ace1
  color white
  font-size 8px
  font-weight 700
  padding 2px 6px
  border-radius 3px

.course-card__actions
  margin-top 20px
  display flex
  gap 12px
  align-items center

.course-card__detail
  flex 1
  height 44px
  border 1px solid #7352ff
  background white
  border-radius 6px
  color $ink
  font-weight 700

.course-card__cart-actions
  display flex
  gap 8px

.course-card__icon-button
  width 44px
  height 44px
  border 0
  border-radius 6px
  background $brand
  color white
  display inline-flex
  align-items center
  justify-content center
  box-shadow 0 8px 18px rgba(111,73,255,.28)

.course-card__icon-button img
  width 28px
  filter brightness(0) invert(1)

.course-card__icon-button svg
  width 18px
  height 18px

.catalog-results__empty
  border 1px solid #e8e3fb
  border-radius 28px
  background linear-gradient(180deg,#fcfbff 0%,#f7f4ff 100%)
  padding 32px

.catalog-results__empty h3
  margin 0 0 12px
  font-size 24px

.catalog-results__empty button
  margin-top 20px
  height 44px
  border 0
  border-radius 8px
  background $brand
  color white
  padding 0 20px

.catalog-cta
  padding-bottom 48px

.catalog-cta__box
  position relative
  overflow hidden
  border-radius 24px
  background linear-gradient(180deg,#f2f3ff 0%,#eef0ff 100%)
  text-align center
  padding 56px 24px
  box-shadow 0 20px 40px rgba(86,70,180,.08)

.catalog-cta__box:before
  content ''
  position absolute
  left 50%
  top -8%
  height 140%
  width 90px
  transform translateX(-50%) skewX(-16deg)
  background rgba(255,255,255,.40)
  pointer-events none

.catalog-cta__box:after
  content ''
  position absolute
  bottom -8%
  left 50%
  height 150px
  width 280px
  transform translateX(-10%)
  background #e8e9fb
  clip-path polygon(24% 0,84% 0,100% 100%,0 100%)
  pointer-events none

.catalog-cta__box-letter
  position absolute
  bottom 16px
  left 50%
  transform translateX(-50%)
  font-size 240px
  font-weight 900
  line-height 1
  color rgba(255,255,255,.35)
  pointer-events none
  user-select none

.catalog-cta__box-content
  position relative
  z-index 1
  max-width 48rem
  margin 0 auto

.catalog-cta__box-content > span
  color $brand
  font-size 14px
  font-weight 800
  letter-spacing .16em
  text-transform uppercase

.catalog-cta__box h2
  margin 16px auto 0
  font-size 32px
  font-weight 800
  line-height 1.1
  letter-spacing -.03em
  color #27223f

.catalog-cta__box p
  max-width 42rem
  margin 24px auto 0
  color #73708e
  font-size 18px
  line-height 32px

.catalog-cta__box button
  display inline-flex
  align-items center
  justify-content center
  margin-top 32px
  height 52px
  border 0
  border-radius 8px
  background linear-gradient(90deg,#6d44f7 0%,#7a52ff 100%)
  color white
  padding 0 32px
  font-weight 600
  font-size 17px
  box-shadow 0 14px 26px rgba(109,68,247,.24)

@media (min-width: 640px)
  .catalog-cta__box
    padding 56px 40px

  .catalog-cta__box h2
    font-size 42px

@media (min-width: 1024px)
  .catalog-cta
    padding-bottom 64px

  .catalog-cta__box
    padding 72px 64px

.catalog-suggestion
  padding-bottom 56px

.catalog-suggestion__box
  position relative
  display flex
  flex-direction column
  gap 28px
  border-radius 24px
  background #6f4cff
  color white
  padding 32px 24px
  box-shadow 0 22px 44px rgba(109,68,247,.2)

.catalog-suggestion__box:before
  content none

.catalog-suggestion__box:after
  content none

.catalog-suggestion__content
  position relative
  z-index 1
  display flex
  flex-direction column
  gap 20px
  min-width 0

.catalog-suggestion__left
  display flex
  align-items flex-start
  gap 16px

.catalog-suggestion__icon
  width 48px
  height 48px
  flex-shrink 0
  display flex
  align-items center
  justify-content center
  border-radius 14px
  background rgba(255,255,255,.14)

.catalog-suggestion__icon svg
  width 24px
  height 24px

.catalog-suggestion__label
  display block
  font-size 12px
  font-weight 800
  text-transform uppercase
  letter-spacing .16em
  color rgba(255,255,255,.72)

.catalog-suggestion__box h3
  margin 8px 0 0
  max-width 280px
  font-size 28px
  font-weight 800
  line-height .95
  letter-spacing -.035em

.catalog-suggestion__content > p
  margin 0
  max-width 760px
  font-size 15px
  line-height 28px
  color rgba(255,255,255,.92)

.catalog-suggestion__cta
  display flex
  flex-direction column
  align-items flex-start
  gap 12px
  flex-shrink 0

.catalog-suggestion__cta button
  display inline-flex
  align-items center
  justify-content center
  height 52px
  border 0
  border-radius 10px
  background white
  color #6f4cff
  padding 0 32px
  font-size 16px
  font-weight 600
  cursor pointer

.catalog-suggestion__cta > p
  margin 0
  font-size 12px
  font-weight 500
  color rgba(255,255,255,.70)

@media (min-width: 1024px)
  .catalog-suggestion
    padding-bottom 80px

  .catalog-suggestion__box
    flex-direction row
    align-items center
    justify-content space-between
    padding 36px 40px

  .catalog-suggestion__content
    flex-direction row
    align-items flex-start
    gap 28px
    flex 1

  .catalog-suggestion__left
    min-width 344px
    flex-shrink 0

  .catalog-suggestion__box h3
    font-size 31px
    max-width 300px

  .catalog-suggestion__content > p
    font-size 16px
    line-height 32px

  .catalog-suggestion__cta
    align-items flex-end
    min-width 300px

  .catalog-suggestion__cta > p
    text-align right


.catalog-faq
  padding-bottom 72px

.catalog-faq__head span
  font-size 12px
  font-weight 800
  color $brand
  text-transform uppercase

.catalog-faq__head h2
  margin 8px 0 18px
  font-size 38px
  font-weight 800
  letter-spacing -.03em

.faq-item
  overflow hidden
  border 1px solid #f1eefc
  border-radius 16px
  background white
  box-shadow 0 10px 24px rgba(31,22,87,.05)
  margin-bottom 12px

.faq-item.is-open
  border-color #d9cffd
  background #fbfaff

.faq-item__toggle
  width 100%
  padding 28px 32px
  border 0
  background transparent
  display flex
  justify-content space-between
  align-items center
  text-align left

.faq-item__toggle span:first-child
  font-size 22px
  font-weight 800
  color $brand

.faq-item__toggle span:last-child
  width 40px
  height 40px
  border-radius 50%
  border 1px solid #d9cffd
  display inline-flex
  align-items center
  justify-content center
  color $brand
  font-size 24px

.faq-item.is-open .faq-item__toggle span:last-child
  background $brand
  color white
  border-color $brand

.faq-item__body
  border-top 1px solid #ece6ff
  padding 24px 32px 28px
  color #6f6a89
  line-height 1.8
