.checkout-layout
  display flex
  gap 24px
  align-items flex-start
  padding-top 32px
  padding-bottom 40px

.checkout-main
  flex 1
  border 1px solid #e7e3f7
  border-radius 24px
  background white
  box-shadow 0 20px 60px rgba(34,22,87,.08)
  padding 28px

.checkout-main__head
  padding-bottom 20px
  border-bottom 1px solid $border

.checkout-main__head span,
.checkout-summary > span,
.checkout-empty span,
.checkout-success__box span
  display inline-flex
  padding 4px 16px
  border-radius 999px
  background $brand-soft
  color $brand
  font-size 12px
  font-weight 700
  text-transform uppercase
  letter-spacing .08em

.checkout-main__head h1,
.checkout-empty h1,
.checkout-success__box h1
  margin 16px 0 12px
  font-size 30px
  font-weight 900
  letter-spacing -.03em
  color #27223f

.checkout-main__head p
  max-width 620px
  margin 0
  font-size 15px
  line-height 1.75
  color #726d8d

.checkout-item
  display flex
  align-items center
  gap 20px
  border 1px solid $border
  border-radius 20px
  background #fcfbff
  padding 16px
  margin-top 16px

.checkout-item__thumb
  width 160px
  height 110px
  border 1px solid #e4dff8
  border-radius 16px
  background linear-gradient(135deg,#ddd2ff 0%,#d4c6ff 55%,#c9bbff 100%)

.checkout-item__content
  flex 1

.checkout-item__content span,
.checkout-item__price span
  font-size 12px
  font-weight 600
  color #8a84a8
  text-transform uppercase
  letter-spacing .08em

.checkout-item__content h2
  margin 8px 0 0
  font-size 20px
  font-weight 900
  line-height 1.15
  letter-spacing -.03em
  color #27223f

.checkout-item__content p
  margin-top 12px
  color $muted
  font-size 14px

.checkout-item__price strong
  display block
  margin-top 8px
  font-size 26px
  font-weight 900
  letter-spacing -.04em
  color #27223f

.checkout-summary
  width 360px
  border 1px solid #ddd7f5
  border-radius 24px
  background linear-gradient(180deg,#453c62 0%,#504a74 100%)
  color white
  padding 24px
  box-shadow 0 24px 60px rgba(20,15,52,.28)

.checkout-summary h2
  margin 16px 0 0
  font-size 26px
  font-weight 900
  letter-spacing -.03em

.checkout-summary__box
  margin-top 24px
  border 1px solid rgba(255,255,255,.1)
  border-radius 18px
  background rgba(255,255,255,.06)
  padding 16px

.checkout-summary__box div
  display flex
  justify-content space-between
  color #d8dbf4
  margin-bottom 12px
  font-size 14px

.checkout-summary__box .is-total
  padding-top 12px
  border-top 1px solid rgba(255,255,255,.1)
  color white

.checkout-summary__box .is-total strong
  font-size 28px
  font-weight 900
  letter-spacing -.04em

.checkout-summary form button,
.checkout-summary > a,
.checkout-empty a,
.checkout-success__actions a
  display flex
  align-items center
  justify-content center
  height 48px
  border-radius 10px
  font-size 15px
  font-weight 600

.checkout-summary form button,
.checkout-empty a,
.checkout-success__actions a:first-child
  width 100%
  border 0
  background linear-gradient(90deg,#6d44f7 0%,#7a52ff 100%)
  color white
  margin-top 20px
  box-shadow 0 14px 28px rgba(111,73,255,.3)

.checkout-summary > a,
.checkout-success__actions a:last-child
  margin-top 12px
  border 1px solid rgba(255,255,255,.18)
  background rgba(255,255,255,.08)
  color white

.checkout-empty,
.checkout-success
  padding 40px 0

.checkout-empty
  width 100%
  border 1px solid #e7e3f7
  border-radius 24px
  background white
  box-shadow 0 20px 60px rgba(34,22,87,.08)
  padding 56px 40px
  text-align center

.checkout-empty p,
.checkout-success__box p
  max-width 620px
  margin 0 auto
  font-size 16px
  line-height 1.75
  color $muted

.checkout-empty a
  display inline-flex
  width auto
  padding 0 24px
  margin-left auto
  margin-right auto

.checkout-success__box
  width 100%
  border 1px solid #e6e2f8
  border-radius 28px
  background linear-gradient(135deg,#f5f1ff 0%,#ffffff 45%,#f7f9ff 100%)
  box-shadow 0 24px 80px rgba(34,22,87,.1)
  padding 64px 32px
  text-align center

.checkout-success__box span
  display inline-flex
  align-items center
  justify-content center
  min-height 28px
  padding 4px 16px
  border-radius 999px
  background #6f49ff
  color white
  font-size 12px
  font-weight 700
  text-transform uppercase
  letter-spacing .08em

.checkout-success__box h1
  font-size 34px
  font-weight 900
  line-height 1.05
  letter-spacing -.04em
  margin-top 24px

.checkout-success__box p
  max-width 620px
  margin 16px auto 0
  font-size 16px
  line-height 1.75
  color #726d8d

.checkout-success__actions
  display flex
  flex-direction column
  gap 12px
  justify-content center
  max-width 420px
  margin 32px auto 0

.checkout-success__actions a
  min-width 0
  padding 0 24px

.checkout-success__actions a:first-child
  width 100%

.checkout-success__actions a:last-child
  border 1px solid #d9d3f4
  background white
  color #27223f

@media (min-width: 640px)
  .checkout-success__box
    padding 64px 40px

  .checkout-success__actions
    flex-direction row
    align-items center

  .checkout-success__actions a
    width auto
