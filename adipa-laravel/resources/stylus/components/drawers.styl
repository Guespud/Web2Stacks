.mobile-drawer,
.cart-drawer
  position fixed
  inset 0
  z-index 90
  opacity 0
  pointer-events none
  transition opacity .22s ease

.mobile-drawer.is-open,
.cart-drawer.is-open
  opacity 1
  pointer-events auto

.mobile-drawer
  background rgba(23,20,42,.44)

.mobile-drawer__panel
  position absolute
  top 0
  left 0
  width 330px
  max-width 82vw
  height 100%
  display flex
  flex-direction column
  background white
  border-right 1px solid #ece9f5
  box-shadow 12px 0 30px rgba(17,11,43,.18)
  overflow hidden
  transform translateX(-100%)
  transition transform .3s ease-out

.mobile-drawer.is-open .mobile-drawer__panel
  transform translateX(0)

.mobile-drawer__header
  position relative
  border-bottom 1px solid #ece9f5
  background white
  padding 16px 20px

.mobile-drawer__header-row
  display flex
  align-items center
  justify-content space-between
  gap 16px

.mobile-drawer__brand
  display inline-flex
  align-items center

.mobile-drawer__brand img
  width 120px

.mobile-drawer__close
  display inline-flex
  width 40px
  height 40px
  min-width 40px
  align-items center
  justify-content center
  border 1px solid #e7e1fb
  border-radius 999px
  background white
  color #7652ff
  font-size 26px
  font-weight 300
  line-height 1
  cursor pointer

.mobile-drawer__back
  display inline-flex
  align-items center
  gap 4px
  border 0
  background transparent
  color #6d44f7
  font-size 13px
  font-weight 600
  cursor pointer

.mobile-drawer__back span:first-child
  font-size 18px
  font-weight 300

.mobile-drawer__nav-shell
  flex 1
  min-height 0
  padding 16px 20px 20px
  overflow-y auto

.mobile-drawer__nav
  overflow hidden
  border 1px solid #ece9f5
  border-radius 16px
  background white

.mobile-drawer__item
  width 100%
  min-height 56px
  display flex
  align-items center
  justify-content space-between
  gap 16px
  padding 12px 16px
  border 0
  border-bottom 1px solid #ece9f5
  background white
  color #27223f
  font-size 18px
  text-align left
  transition background-color .18s ease

.mobile-drawer__item:last-child
  border-bottom 0

.mobile-drawer__item .is-strong,
.mobile-drawer__item > span:first-child
  font-weight 600
  line-height 1.15

.mobile-drawer__item .is-strong
  font-weight 800

.mobile-drawer__item.is-pink
  background #fff5f8

.mobile-drawer__item:hover,
.mobile-drawer__subitem:hover
  background #faf8ff

.mobile-drawer__item-meta
  display inline-flex
  align-items center
  gap 10px
  color #9a96b0

.mobile-drawer__item-chevron
  font-size 22px
  line-height 1

.mobile-drawer__section-label
  border-bottom 1px solid #ece9f5
  padding 12px 16px
  color #9a94ba
  font-size 12px
  font-weight 800
  letter-spacing .12em
  text-transform uppercase

.mobile-drawer__subitem
  display flex
  min-height 52px
  align-items center
  padding 12px 16px
  border-bottom 1px solid #ece9f5
  color #27223f
  font-size 16px
  font-weight 600

.mobile-drawer__subitem:last-child
  border-bottom 0

.mobile-drawer__badge
  display inline-flex
  align-items center
  justify-content center
  padding 4px 10px
  border-radius 999px
  background #ff2f7d
  color white
  font-size 10px
  font-weight 800
  text-transform uppercase
  letter-spacing .08em

.mobile-drawer__badge.is-free
  background #6d44f7

.mobile-drawer__footer
  padding 16px 20px 20px
  border-top 1px solid #ece9f5
  background white

.mobile-drawer__auth
  display grid
  grid-template-columns 1fr 1fr
  gap 10px
  align-items stretch

.mobile-drawer__login,
.mobile-drawer__register
  width 100%
  min-width 0
  height 44px
  border-radius 10px
  font-size 14px
  font-weight 600
  white-space nowrap
  padding 0 16px
  display flex
  align-items center
  justify-content center

.mobile-drawer__login
  border 0
  background #6d44f7
  color white
  box-shadow 0 10px 20px rgba(109,68,247,.18)

.mobile-drawer__register
  border 1px solid #ddd4ff
  background #faf8ff
  color #6d44f7

.mobile-drawer__contact
  margin-top 14px
  display flex
  align-items center
  justify-content space-between
  gap 12px
  border 1px solid #ece9f5
  border-radius 12px
  background #fcfbff
  padding 12px 16px

.mobile-drawer__contact-copy span
  display block
  margin-bottom 5px
  color #8b86a6
  font-size 11px
  font-weight 800
  text-transform uppercase
  letter-spacing .16em

.mobile-drawer__contact-copy strong
  display block
  margin-top 4px
  color #2c2844
  font-size 14px
  font-weight 700
  line-height 1.2

.mobile-drawer__whatsapp
  width 44px
  height 44px
  min-width 44px
  border 0
  border-radius 50%
  background #3cc54a
  display inline-flex
  align-items center
  justify-content center
  box-shadow 0 10px 20px rgba(60,197,74,.22)

.mobile-drawer__whatsapp img
  width 24px

.cart-drawer
  background rgba(47,47,47,.45)

.cart-drawer__panel
  position absolute
  right 0
  top 0
  width 100%
  max-width 364px
  height 100%
  display flex
  flex-direction column
  background white
  box-shadow -20px 0 50px rgba(0,0,0,.18)
  transform translateX(100%)
  transition transform .22s ease

.cart-drawer.is-open .cart-drawer__panel
  transform translateX(0)

.cart-drawer__header,
.cart-drawer__footer
  padding 20px 20px
  border-color $border

.cart-drawer__header
  border-bottom 1px solid $border
  display flex
  justify-content space-between
  align-items flex-start

.cart-drawer__header h2
  margin 0
  font-size 20px
  font-weight 800
  line-height 1.1
  color #27223f

.cart-drawer__header p
  margin 7px 0 0
  font-size 12px
  font-weight 600
  line-height 1.2
  color #7b7697

.cart-drawer__close
  border 0
  background transparent
  color #7652ff
  font-size 32px
  font-weight 300
  line-height 1
  padding 0

.cart-drawer__body
  flex 1
  overflow-y auto
  padding 18px 20px

.cart-drawer__empty
  border 1px dashed #d8d2f4
  background #faf8ff
  border-radius 10px
  padding 32px 20px
  text-align center
  color #7b7697
  font-size 14px

.cart-item
  display flex
  gap 16px
  border 1px solid $border
  border-radius 12px
  padding 11px
  margin-bottom 14px

.cart-item__thumb
  width 84px
  min-width 84px
  height 70px
  border-radius 8px
  background linear-gradient(135deg,#ddd2ff 0%,#d4c6ff 55%,#c9bbff 100%)
  display flex
  align-items center
  justify-content center
  padding 10px

.cart-item__thumb img
  width 62px

.cart-item__content h3
  margin 0
  font-size 14px
  font-weight 800
  line-height 1.25
  color #27223f
  display -webkit-box
  -webkit-line-clamp 3
  -webkit-box-orient vertical
  overflow hidden

.cart-item__content strong
  display block
  margin-top 10px
  font-size 15px
  font-weight 900
  color #27223f

.cart-item__content button
  margin-top 12px
  border 0
  background transparent
  color $brand
  font-size 12px
  font-weight 700
  padding 0

.cart-drawer__summary
  border 1px solid $border
  border-radius 12px
  background #faf8ff
  padding 14px 14px
  margin-bottom 16px

.cart-drawer__summary div
  display flex
  justify-content space-between
  font-size 13px
  color $muted
  margin-bottom 10px
  align-items center

.cart-drawer__summary .is-total
  margin-top 12px
  padding-top 12px
  border-top 1px solid $border
  color $ink

.cart-drawer__summary .is-total span
  font-size 13px
  font-weight 700

.cart-drawer__summary .is-total strong
  font-size 22px
  font-weight 900
  letter-spacing -.03em

.cart-drawer__summary strong
  color $ink
  font-weight 600

.cart-drawer__checkout
  display flex
  align-items center
  justify-content center
  height 42px
  border-radius 8px
  background linear-gradient(90deg,#6d44f7 0%,#7a52ff 100%)
  color white
  font-size 15px
  font-weight 600

.cart-drawer__checkout.is-disabled
  pointer-events none
  opacity .55

@media (max-width: 420px)
  .mobile-drawer__panel
    width calc(100vw - 18vw)
    max-width calc(100vw - 18vw)

  .mobile-drawer__header
    padding 16px

  .mobile-drawer__nav-shell,
  .mobile-drawer__footer
    padding-left 16px
    padding-right 16px

  .mobile-drawer__item
    min-height 56px
    font-size 18px
